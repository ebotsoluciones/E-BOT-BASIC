# ──────────────────────────────────────────────────────────────────────────────
# E-BOT BASIC 🦙 — variables de entorno
# Copiá este archivo como .env y completá los valores reales.
# ──────────────────────────────────────────────────────────────────────────────

# Modo test: en true cualquiera puede escribir "adm" para probar el panel admin.
# Cambiá a false antes de entregar al cliente.
MODO_TEST=true

# Números administradores (solo se usan cuando MODO_TEST=false)
# Formato Twilio: whatsapp:+549XXXXXXXXXX
# Separados por coma si hay más de uno.
ADMINS=whatsapp:+5491100000000

# Credenciales Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Carpeta donde se guardan los archivos JSON (opcional, default: data/)
# DATA_DIR=data
